{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=acceptance_spec_db;User=root;Password=abc+123;CharSet=utf8mb4;"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000", "http://localhost:5173", "http://localhost:8080"]
  },
  "JwtAuth": {
    "Issuer": "AcceptanceSpecSystem",
    "Audience": "AcceptanceSpecSystem.Web",
    "SigningKey": "DevOnly_ReplaceThisWithLongRandomSecret_1234567890",
    "AccessTokenMinutes": 120,
    "RefreshTokenDays": 7
  },
  "DataProtection": {
    "KeysPath": ".\\data-protection-keys"
  },
  "FileStorage": {
    "BasePath": "."
  },
  "AuditLog": {
    "EnableAutoCleanup": true,
    "RetentionDays": 30,
    "CleanupIntervalHours": 24
  }
}
